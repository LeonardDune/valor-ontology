@prefix app:   <https://valor-ecosystem.nl/ontology/application#> .
@prefix gufo:  <http://purl.org/nemo/gufo#> .
@prefix ufoc:  <https://valor-ecosystem.nl/ontology/ufo-c#> .
@prefix valor: <https://valor-ecosystem.nl/ontology/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix vo:    <https://valor-ecosystem.nl/ontology/> .
# TRiG version of 00k-application.ttl
<https://valor-ecosystem.nl/ontology/application> {
###############################################################################
#  VALOR-O — Module 00k: VALOR Toepassingsontologie (Application)
#
#  Namespace  : https://valor-ecosystem.nl/ontology/application#  (prefix app:)
#  Versie     : 0.2  (maart 2026)
#  Imports    : 00a-gufo-core, 00c-ufo-c, 00j-tessera
#
#  Wijzigingen t.o.v. v0.1:
#   [K-001] app:mapsToRBACRole toegevoegd als DatatypeProperty op ParticipantRole
#           Applicatie-binding: VALOR-O rol → Neo4j RBAC-rolnaam. (US-3.6 #354)
#   [K-002] app:roleWeight toegevoegd als DatatypeProperty op ParticipantRole
#           Numeriek gewicht voor hiërarchische RBAC-vergelijking. (US-3.6 #354)
#   [K-003] Instantietriples toegevoegd voor mapsToRBACRole en roleWeight
#           per rol. (US-3.6 #354)
#
#  Architectuurprincipe (DD-062):
#    Deze module definieert de VALOR-specifieke toepassingsstructuren
#    die het ontwerpproces organiseren: DesignSpace, DesignPhase,
#    DesignAlternative en Participant. valor:Issue is hier gedefinieerd
#    en niet in 00h-causa, omdat Issue de top-level entiteit is die
#    alle perspectieven verbindt.
#
#  Structuur:
#    §A  Issue
#    §B  DesignSpace
#    §C  DesignPhase
#    §D  PhaseTransition
#    §E  DesignAlternative
#    §F  Participant
#    §G  ParticipantRole
#    §H  Properties
###############################################################################


###############################################################################
#  Ontologie-declaratie
###############################################################################

vo:application
    a owl:Ontology ;
    rdfs:label "VALOR-O Module 00k — VALOR Toepassingsontologie"@nl ;
    owl:imports <https://valor-ecosystem.nl/ontology/gufo-core> ;
    owl:imports <https://valor-ecosystem.nl/ontology/ufo-c> ;
    owl:imports <https://valor-ecosystem.nl/ontology/tessera> ;
    owl:versionInfo "0.2" ;
    owl:priorVersion "0.1" ;
    rdfs:comment
        """Definieert de VALOR-O toepassingsstructuren: Issue, DesignSpace,
         DesignPhase, DesignAlternative en Participant. (DD-062)
         v0.2: mapsToRBACRole en roleWeight toegevoegd aan ParticipantRole. (K-001, K-002)"""@nl .


###############################################################################
#  §A — Issue
###############################################################################

valor:Issue
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf ufoc:SocialObject ;
    rdfs:label "Issue"@en , "Vraagstuk"@nl ;
    rdfs:comment "Een maatschappelijk vraagstuk. (DD-054, DD-062)"@nl .

valor:concernedWithSituation
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "concerned with situation"@en , "betreft situatie"@nl ;
    rdfs:domain valor:Issue ;
    rdfs:range  gufo:Situation ;
    rdfs:comment "De situatie die het Issue aanleiding geeft. (DD-054, DD-062)"@nl .

valor:hasConcernedAgent
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "has concerned agent"@en , "heeft betrokken agent"@nl ;
    rdfs:domain valor:Issue ;
    rdfs:range  ufoc:Agent ;
    rdfs:comment "De Agent(s) wiens Concern dit Issue constitueert. (DD-054, DD-062)"@nl .

valor:hasDesignSpace
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "has design space"@en , "heeft design space"@nl ;
    rdfs:domain valor:Issue ;
    rdfs:range  app:DesignSpace ;
    rdfs:comment "De DesignSpace(s) voor dit Issue. (DD-062)"@nl .


###############################################################################
#  §B — DesignSpace
###############################################################################

app:DesignSpace
    a owl:Class ;
    rdf:type gufo:Kind ;
    valor:ontoumlStereotype "kind" ;
    rdfs:subClassOf gufo:FunctionalComplex ;
    rdfs:label "DesignSpace"@en , "Ontwerpruimte"@nl ;
    rdfs:comment "De gestructureerde ontwerpomgeving voor één valor:Issue. (DD-062, DD-066)"@nl .

app:DesignSpaceStatus
    a owl:Class ;
    rdf:type gufo:NonQualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "mode" ;
    rdfs:subClassOf gufo:IntrinsicMode ;
    rdfs:label "DesignSpaceStatus"@en , "Status van de DesignSpace"@nl ;
    rdfs:comment "Active, Completed of Archived. (DD-062)"@nl .

app:ActiveDesignSpace     a app:DesignSpaceStatus ; rdfs:label "Active"@en , "Actief"@nl .
app:CompletedDesignSpace  a app:DesignSpaceStatus ; rdfs:label "Completed"@en , "Afgerond"@nl .
app:ArchivedDesignSpace   a app:DesignSpaceStatus ; rdfs:label "Archived"@en , "Gearchiveerd"@nl .


###############################################################################
#  §C — DesignPhase
###############################################################################

app:DesignPhase
    a owl:Class ;
    rdf:type gufo:SituationType ;
    valor:ontoumlStereotype "situation" ;
    rdfs:subClassOf gufo:Situation ;
    rdfs:label "DesignPhase"@en , "Ontwerpfase"@nl ;
    rdfs:comment "Een afgebakende periode in de lifecycle van een DesignSpace. (DD-062)"@nl .

app:PhaseStatus
    a owl:Class ;
    rdf:type gufo:NonQualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "mode" ;
    rdfs:subClassOf gufo:IntrinsicMode ;
    rdfs:label "PhaseStatus"@en , "Fasestatus"@nl ;
    rdfs:comment "Active, Closed of Archived. (DD-062)"@nl .

app:ActivePhase    a app:PhaseStatus ; rdfs:label "Active"@en , "Actief"@nl .
app:ClosedPhase    a app:PhaseStatus ; rdfs:label "Closed"@en , "Gesloten"@nl .
app:ArchivedPhase  a app:PhaseStatus ; rdfs:label "Archived"@en , "Gearchiveerd"@nl .

app:PhaseModel
    a owl:Class ;
    rdf:type gufo:NonQualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "mode" ;
    rdfs:subClassOf gufo:IntrinsicMode ;
    rdfs:label "PhaseModel"@en , "Fasemodel"@nl ;
    rdfs:comment "Het fasemodel voor deze DesignSpace. (DD-062)"@nl .

app:DesignThinkingModel  a app:PhaseModel ; rdfs:label "Design Thinking"@en .
app:DoubleDiamondModel   a app:PhaseModel ; rdfs:label "Double Diamond"@en .
app:AgileModel           a app:PhaseModel ; rdfs:label "Agile"@en .
app:PolicyCycleModel     a app:PhaseModel ; rdfs:label "Policy Cycle"@en , "Beleidslevenscyclus"@nl .


###############################################################################
#  §D — PhaseTransition
###############################################################################

app:PhaseTransition
    a owl:Class ;
    rdf:type gufo:EventType ;
    valor:ontoumlStereotype "event" ;
    rdfs:subClassOf valor:DecisionEpisode ;
    rdfs:label "PhaseTransition"@en , "Faseovergang"@nl ;
    rdfs:comment "Faseovergang als valor:DecisionEpisode. (DD-062)"@nl .


###############################################################################
#  §E — DesignAlternative
###############################################################################

app:DesignAlternative
    a owl:Class ;
    rdf:type gufo:SituationType ;
    valor:ontoumlStereotype "situation" ;
    rdfs:subClassOf gufo:Situation ;
    rdfs:label "DesignAlternative"@en , "Ontwerpalternatief"@nl ;
    rdfs:comment "Een oplossingsrichting als named graph in Fuseki. (DD-062, DD-066)"@nl .

app:AlternativeStatus
    a owl:Class ;
    rdf:type gufo:NonQualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "mode" ;
    rdfs:subClassOf gufo:IntrinsicMode ;
    rdfs:label "AlternativeStatus"@en , "Alternatiefstatus"@nl ;
    rdfs:comment "De status van een DesignAlternative. (DD-062)"@nl .

app:ActiveAlternative    a app:AlternativeStatus ; rdfs:label "Active"@en , "Actief"@nl .
app:SelectedAlternative  a app:AlternativeStatus ; rdfs:label "Selected"@en , "Geselecteerd"@nl .
app:ArchivedAlternative  a app:AlternativeStatus ; rdfs:label "Archived"@en , "Gearchiveerd"@nl .


###############################################################################
#  §F — Participant
###############################################################################

app:Participant
    a owl:Class ;
    rdf:type gufo:Role ;
    valor:ontoumlStereotype "role" ;
    rdfs:subClassOf ufoc:Agent ;
    rdfs:label "Participant"@en , "Deelnemer"@nl ;
    rdfs:comment "Een ufoc:Agent met een rol in een DesignSpace. (DD-062)"@nl .


###############################################################################
#  §G — ParticipantRole (zes rollen)
###############################################################################

app:ParticipantRole
    a owl:Class ;
    rdf:type gufo:NonQualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "mode" ;
    rdfs:subClassOf gufo:IntrinsicMode ;
    rdfs:label "ParticipantRole"@en , "Deelnemersrol"@nl ;
    rdfs:comment "De rol van een Participant in een DesignSpace. (DD-062)"@nl .

app:InitiatorRole
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf app:ParticipantRole ;
    rdfs:label "Initiator"@en , "Initiator"@nl ;
    rdfs:comment "Maakt de DesignSpace aan en bepaalt governance. Heeft stemrecht. (DD-062)"@nl .

app:FacilitatorRole
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf app:ParticipantRole ;
    rdfs:label "Facilitator"@en , "Facilitator"@nl ;
    rdfs:comment "Sessiebegeleid en agent-configuratie. Geen stemrecht. (DD-062)"@nl .

app:ContributorRole
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf app:ParticipantRole ;
    rdfs:label "Contributor"@en , "Bijdrager"@nl ;
    rdfs:comment "Voegt Tesserae toe. Heeft stemrecht. (DD-062)"@nl .

app:ExpertRole
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf app:ParticipantRole ;
    rdfs:label "Expert"@en , "Expert"@nl ;
    rdfs:comment "Voegt Tesserae toe. Geen stemrecht. (DD-062)"@nl .

app:ObserverRole
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf app:ParticipantRole ;
    rdfs:label "Observer"@en , "Waarnemer"@nl ;
    rdfs:comment "Leestoegang. Geen schrijftoegang, geen stemrecht. (DD-062)"@nl .

app:EngineerRole
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf app:ParticipantRole ;
    rdfs:label "Engineer"@en , "Engineer"@nl ;
    rdfs:comment "Toegang tot Forma en SPARQL. Geen stemrecht. (DD-062)"@nl .


###############################################################################
#  §H — Properties
###############################################################################

# ── app:DesignSpace ───────────────────────────────────────────────────────────

app:addressesIssue
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "addresses issue"@en , "adresseert vraagstuk"@nl ;
    rdfs:domain app:DesignSpace ;
    rdfs:range  valor:Issue ;
    rdfs:comment "Het Issue waarop deze DesignSpace betrekking heeft. (DD-062)"@nl .

app:hasPhase
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "has phase"@en , "heeft fase"@nl ;
    rdfs:domain app:DesignSpace ;
    rdfs:range  app:DesignPhase ;
    rdfs:comment "De Fasen van deze DesignSpace. (DD-062)"@nl .

app:hasAlternative
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "has alternative"@en , "heeft alternatief"@nl ;
    rdfs:domain app:DesignSpace ;
    rdfs:range  app:DesignAlternative ;
    rdfs:comment "De Alternatieven van deze DesignSpace. (DD-062)"@nl .

app:hasParticipantMember
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "has participant member"@en , "heeft deelnemer"@nl ;
    rdfs:domain app:DesignSpace ;
    rdfs:range  app:Participant ;
    rdfs:comment "De Participants van deze DesignSpace. (DD-062)"@nl .

app:designSpaceStatus
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "design space status"@en , "status van de design space"@nl ;
    rdfs:domain app:DesignSpace ;
    rdfs:range  app:DesignSpaceStatus ;
    rdfs:comment "De status van de DesignSpace. (DD-062)"@nl .

app:usesPhaseModel
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "uses phase model"@en , "gebruikt fasemodel"@nl ;
    rdfs:domain app:DesignSpace ;
    rdfs:range  app:PhaseModel ;
    rdfs:comment "Het fasemodel van deze DesignSpace. (DD-062)"@nl .

app:fusekiNamedGraphBase
    a owl:DatatypeProperty ;
    rdfs:label "Fuseki named graph base IRI"@en ;
    rdfs:domain app:DesignSpace ;
    rdfs:range  xsd:anyURI ;
    rdfs:comment "Basis-IRI voor de named graphs van deze DesignSpace. (DD-066)"@nl .

# ── app:DesignPhase ───────────────────────────────────────────────────────────

app:phaseStatus
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "phase status"@en , "fasestatus"@nl ;
    rdfs:domain app:DesignPhase ;
    rdfs:range  app:PhaseStatus ;
    rdfs:comment "De status van de DesignPhase. (DD-062)"@nl .

app:phaseBeginPoint
    a owl:DatatypeProperty ;
    rdfs:label "phase begin point"@en , "fase beginpunt"@nl ;
    rdfs:domain app:DesignPhase ;
    rdfs:range  xsd:dateTime ;
    rdfs:comment "Tijdstip waarop de fase begon. (DD-062)"@nl .

app:phaseEndPoint
    a owl:DatatypeProperty ;
    rdfs:label "phase end point"@en , "fase eindpunt"@nl ;
    rdfs:domain app:DesignPhase ;
    rdfs:range  xsd:dateTime ;
    rdfs:comment "Tijdstip waarop de fase werd afgesloten. (DD-062)"@nl .

app:hasPhaseTransition
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "has phase transition"@en , "heeft faseovergang"@nl ;
    rdfs:domain app:DesignPhase ;
    rdfs:range  app:PhaseTransition ;
    rdfs:comment "De PhaseTransition waarmee deze fase werd afgesloten. (DD-062)"@nl .

app:phaseSequenceNumber
    a owl:DatatypeProperty ;
    rdfs:label "phase sequence number"@en , "fasenummer"@nl ;
    rdfs:domain app:DesignPhase ;
    rdfs:range  xsd:integer ;
    rdfs:comment "Volgnummer van de fase (1, 2, 3, ...). (DD-062)"@nl .

# ── app:DesignAlternative ─────────────────────────────────────────────────────

app:alternativeStatus
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "alternative status"@en , "alternatiefstatus"@nl ;
    rdfs:domain app:DesignAlternative ;
    rdfs:range  app:AlternativeStatus ;
    rdfs:comment "De status van het alternatief. (DD-062)"@nl .

app:alternativeNamedGraphIRI
    a owl:DatatypeProperty ;
    rdfs:label "alternative named graph IRI"@en ;
    rdfs:domain app:DesignAlternative ;
    rdfs:range  xsd:anyURI ;
    rdfs:comment "IRI van de named graph voor dit alternatief. (DD-066)"@nl .

app:alternativeCreatedAt
    a owl:DatatypeProperty ;
    rdfs:label "alternative created at"@en , "alternatief aangemaakt op"@nl ;
    rdfs:domain app:DesignAlternative ;
    rdfs:range  xsd:dateTime ;
    rdfs:comment "Tijdstip van aanmaken. (DD-062)"@nl .

app:alternativeCreatedBy
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "alternative created by"@en , "alternatief aangemaakt door"@nl ;
    rdfs:domain app:DesignAlternative ;
    rdfs:range  app:Participant ;
    rdfs:comment "De Participant die dit alternatief aanmaakte. (DD-062)"@nl .

# ── app:Participant ───────────────────────────────────────────────────────────

app:hasRole
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "has role"@en , "heeft rol"@nl ;
    rdfs:domain app:Participant ;
    rdfs:range  app:ParticipantRole ;
    rdfs:comment "De rol van de Participant in de DesignSpace. (DD-062)"@nl .

app:participatesIn
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "participates in"@en , "neemt deel aan"@nl ;
    rdfs:domain app:Participant ;
    rdfs:range  app:DesignSpace ;
    rdfs:comment "De DesignSpace(s) waaraan deze Participant deelneemt. (DD-062)"@nl .

app:participantInvitedAt
    a owl:DatatypeProperty ;
    rdfs:label "participant invited at"@en , "deelnemer uitgenodigd op"@nl ;
    rdfs:domain app:Participant ;
    rdfs:range  xsd:dateTime ;
    rdfs:comment "Tijdstip van uitnodiging. (DD-062)"@nl .

app:participantInvitedBy
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "participant invited by"@en , "deelnemer uitgenodigd door"@nl ;
    rdfs:domain app:Participant ;
    rdfs:range  app:Participant ;
    rdfs:comment "De uitnodigende Participant. (DD-062)"@nl .

app:isPseudonymised
    a owl:DatatypeProperty ;
    rdfs:label "is pseudonymised"@en , "is gepseudonimiseerd"@nl ;
    rdfs:domain app:Participant ;
    rdfs:range  xsd:boolean ;
    rdfs:comment "Of bijdragen pseudoniem worden weergegeven. (DD-062)"@nl .

# ── app:ParticipantRole ───────────────────────────────────────────────────────

app:hasVotingRight
    a owl:DatatypeProperty ;
    rdfs:label "has voting right"@en , "heeft stemrecht"@nl ;
    rdfs:domain app:ParticipantRole ;
    rdfs:range  xsd:boolean ;
    rdfs:comment
        """Of deze ParticipantRole stemrecht heeft in DecisionEpisodes.
         Initiator en Contributor: true. Overige rollen: false. (DD-062)"""@nl .

app:mapsToRBACRole
    a owl:DatatypeProperty ;
    rdfs:label "maps to RBAC role"@en , "mapped naar RBAC-rol"@nl ;
    rdfs:domain app:ParticipantRole ;
    rdfs:range  xsd:string ;
    rdfs:comment
        """De Neo4j RBAC-rolnaam (admin, moderator, member, viewer) die
         correspondeert met deze ParticipantRole. Application-binding voor
         het VALOR-backend: bepaalt welke Neo4j HAS_ROLE-relatie wordt
         aangemaakt bij toewijzing van een Participant. (K-001, US-3.6 #354)"""@nl .

app:roleWeight
    a owl:DatatypeProperty ;
    rdfs:label "role weight"@en , "rolgewicht"@nl ;
    rdfs:domain app:ParticipantRole ;
    rdfs:range  xsd:integer ;
    rdfs:comment
        """Numeriek gewicht voor hiërarchische RBAC-vergelijking in
         check_permission(). Hogere waarde = meer rechten.
         Initiator=30, Facilitator=25, Contributor=20,
         Expert=15, Engineer=15, Observer=10. (K-002, US-3.6 #354)"""@nl .

# ── ParticipantRole instanties ────────────────────────────────────────────────

app:InitiatorRole
    app:hasVotingRight   true ;
    app:mapsToRBACRole   "admin" ;
    app:roleWeight       30 .

app:FacilitatorRole
    app:hasVotingRight   false ;
    app:mapsToRBACRole   "moderator" ;
    app:roleWeight       25 .

app:ContributorRole
    app:hasVotingRight   true ;
    app:mapsToRBACRole   "member" ;
    app:roleWeight       20 .

app:ExpertRole
    app:hasVotingRight   false ;
    app:mapsToRBACRole   "member" ;
    app:roleWeight       15 .

app:EngineerRole
    app:hasVotingRight   false ;
    app:mapsToRBACRole   "member" ;
    app:roleWeight       15 .

app:ObserverRole
    app:hasVotingRight   false ;
    app:mapsToRBACRole   "viewer" ;
    app:roleWeight       10 .

###############################################################################
#  Einde module 00k-application.trig (v0.2)
###############################################################################
}
