@prefix void: <http://rdfs.org/ns/void#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix vo: <https://valor-ecosystem.nl/ontology/> .
@prefix gufo: <http://purl.org/nemo/gufo#> .

# catalog dataset
<https://valor-ecosystem.nl/void/catalog> a void:Dataset ;
    dcterms:title "VALOR-O ontology & shapes catalog"@nl ;
    dcterms:description "VoID metadata voor alle VALOR-O module graphs"@nl ;
    dcterms:creator "VALOR-O development team" ;
    dcterms:issued "2026-03-04"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    void:triples 10000 ;
    void:sparqlEndpoint <https://valor-ecosystem.nl/sparql> ;
    void:dataDump <https://valor-ecosystem.nl/data/valor-void.trig> ;
    void:subset
        <https://valor-ecosystem.nl/ontology/gufo-core> ,
        <https://valor-ecosystem.nl/ontology/ufo-b> ,
        <https://valor-ecosystem.nl/ontology/ufo-c> ,
        <https://valor-ecosystem.nl/ontology/ufo-l> ,
        <https://valor-ecosystem.nl/ontology/coodm> ,
        <https://valor-ecosystem.nl/ontology/cover> ,
        <https://valor-ecosystem.nl/ontology/acta> ,
        <https://valor-ecosystem.nl/ontology/causa> ,
        <https://valor-ecosystem.nl/ontology/socia> ,
        <https://valor-ecosystem.nl/shacl/gufo-core> ,
        <https://valor-ecosystem.nl/shacl/ufo-b> ,
        <https://valor-ecosystem.nl/shacl/ufo-c> ,
        <https://valor-ecosystem.nl/shacl/ufo-l> ,
        <https://valor-ecosystem.nl/shacl/coodm> ,
        <https://valor-ecosystem.nl/shacl/cover> ,
        <https://valor-ecosystem.nl/shacl/acta> ,
        <https://valor-ecosystem.nl/shacl/causa> ,
        <https://valor-ecosystem.nl/shacl/socia> .

# individual datasets

<https://valor-ecosystem.nl/ontology/gufo-core> a void:Dataset ;
    dcterms:title "gUFO Core ontology" ;
    dcterms:description "Taxonomy of Individuals and Types foundational ontology." ;
    dcterms:creator "VALOR-O development team" ;
    dcterms:issued "2026-03-04"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    void:triples 5270 ;
    void:sparqlEndpoint <https://valor-ecosystem.nl/sparql> ;
    void:dataDump <https://valor-ecosystem.nl/data/gufo-core.trig> ;
    void:vocabulary gufo: .

<https://valor-ecosystem.nl/shacl/gufo-core> a void:Dataset ;
    dcterms:title "SHACL shapes for gUFO Core" ;
