@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix valor:  <https://valor-ecosystem.nl/ontology/> .
@prefix nexus:  <https://valor-ecosystem.nl/ontology/nexus#> .
@prefix app:    <https://valor-ecosystem.nl/ontology/application#> .
@prefix ufoc:   <https://valor-ecosystem.nl/ontology/ufo-c#> .
@prefix gufo:   <http://purl.org/nemo/gufo#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix shvc:   <https://valor-ecosystem.nl/shacl/valor-core#> .
@prefix vo:     <https://valor-ecosystem.nl/ontology/> .

<https://valor-ecosystem.nl/shacl/valor-core> {

    ###############################################################################
    # VALOR-O — SHACL Shapes: VALOR-CORE (Module 00s)
    #
    # Shapes VC-1 through VC-5 (DD-091); SC-01, SC-02 (S-001)
    # Version : 0.2  |  March 2026
    #
    # Wijzigingen t.o.v. v0.1:
    #   [SC-01] DesignSpace vereist valor:hasHardEthicsCompliance (S-001)
    #   [SC-02] DesignSpace vereist valor:hasSoftEthicsCommitment (S-001)
    ###############################################################################

    shvc:
        a owl:Ontology ;
        dcterms:title "VALOR-O SHACL — VALOR-CORE Toepassingsontologie kernlaag"@nl ;
        owl:versionInfo "0.1" .

    # Prefix declaration block for SPARQL constraints
    shvc:
        a sh:PrefixDeclaration ;
        sh:declare [ sh:prefix "valor" ;
                     sh:namespace "https://valor-ecosystem.nl/ontology/"^^xsd:anyURI ] ;
        sh:declare [ sh:prefix "nexus" ;
                     sh:namespace "https://valor-ecosystem.nl/ontology/nexus#"^^xsd:anyURI ] ;
        sh:declare [ sh:prefix "ufoc"  ;
                     sh:namespace "https://valor-ecosystem.nl/ontology/ufo-c#"^^xsd:anyURI ] ;
        sh:declare [ sh:prefix "gufo"  ;
                     sh:namespace "http://purl.org/nemo/gufo#"^^xsd:anyURI ] ;
        sh:declare [ sh:prefix "xsd"   ;
                     sh:namespace "http://www.w3.org/2001/XMLSchema#"^^xsd:anyURI ] .


    ###############################################################################
    # VC-1 — IssueCommunity must have concern about at least one Issue
    ###############################################################################

    valor:IssueCommunityShape
        a sh:NodeShape ;
        sh:targetClass valor:IssueCommunity ;
        sh:name "IssueCommunityShape" ;
        sh:description
            """VC-1: Een IssueCommunity moet betrokkenheid hebben over ten
             minste één Issue via valor:hasConcernAbout (DD-091).""" ;
        sh:property [
            sh:path     valor:hasConcernAbout ;
            sh:minCount 1 ;
            sh:class    valor:Issue ;
            sh:message  "VC-1: IssueCommunity.hasConcernAbout vereist minimaal één valor:Issue (DD-091)."
        ] .


    ###############################################################################
    # VC-2 — Issue must be grounded in a Situation
    ###############################################################################

    valor:IssueShape
        a sh:NodeShape ;
        sh:targetClass valor:Issue ;
        sh:name "IssueShape" ;
        sh:description
            """VC-2: Een Issue moet gegrond zijn in een onderliggende
             gufo:Situation via valor:concernedWithSituation (DD-091).""" ;
        sh:property [
            sh:path     valor:concernedWithSituation ;
            sh:minCount 1 ;
            sh:class    gufo:Situation ;
            sh:message  "VC-2: Issue.concernedWithSituation vereist minimaal één gufo:Situation (DD-091)."
        ] .


    ###############################################################################
    # VC-3 — EcosystemAgent must address at least one Issue (legitimacy check)
    ###############################################################################

    valor:EcosystemAgentLegitimacyShape
        a sh:NodeShape ;
        sh:targetClass nexus:EcosystemAgent ;
        sh:name "EcosystemAgentLegitimacyShape" ;
        sh:description
            """VC-3: Een EcosystemAgent moet ten minste één Issue adresseren
             via nexus:addressesIssue. Een ecosysteem zonder legitimeringsbasis
             mist zijn democratische grondslag (DD-091).""" ;
        sh:property [
            sh:path     nexus:addressesIssue ;
            sh:minCount 1 ;
            sh:class    valor:Issue ;
            sh:message  "VC-3: EcosystemAgent.addressesIssue vereist minimaal één valor:Issue — democratische legitimering ontbreekt (DD-091)."
        ] .


    ###############################################################################
    # VC-4 — Issue must be addressed in at least one DesignSpace
    ###############################################################################

    valor:IssueDesignSpaceShape
        a sh:NodeShape ;
        sh:targetClass valor:Issue ;
        sh:name "IssueDesignSpaceShape" ;
        sh:description
            """VC-4 (waarschuwing): Een Issue dat geen DesignSpace heeft is
             nog niet geoperationaliseerd in het VALOR-ontwerpproces.""" ;
        sh:severity sh:Warning ;
        sh:sparql [
            sh:name    "VC-4-issue-in-designspace" ;
            sh:message "VC-4 (waarschuwing): Issue heeft geen valor:isAddressedInDesignSpace — is het Issue al geoperationaliseerd?" ;
            sh:prefixes shvc: ;
            sh:select  """
                SELECT $this WHERE {
                    FILTER NOT EXISTS {
                        $this valor:isAddressedInDesignSpace ?ds .
                    }
                }
            """
        ] .


    ###############################################################################
    # VC-5 — CollectiveIntentionalCommunity partition: IssueCommunity OR EcosystemAgent
    ###############################################################################

    valor:CollectiveIntentionalCommunityPartitionShape
        a sh:NodeShape ;
        sh:targetClass valor:CollectiveIntentionalCommunity ;
        sh:name "CollectiveIntentionalCommunityPartitionShape" ;
        sh:description
            """VC-5: Een CollectiveIntentionalCommunity moet een IssueCommunity
             of een EcosystemAgent zijn (DD-091: de twee modi van collectieve
             intentionaliteit).""" ;
        sh:or (
            [ sh:class valor:IssueCommunity  ]
            [ sh:class nexus:EcosystemAgent  ]
        ) ;
        sh:message "VC-5: CollectiveIntentionalCommunity moet valor:IssueCommunity of nexus:EcosystemAgent zijn (DD-091)." .


    ###############################################################################
    # SC-01 — DesignSpace vereist HardEthicsCompliance  (S-001)
    ###############################################################################

    valor:DesignSpaceHardEthicsShape
        a sh:NodeShape ;
        sh:targetClass app:DesignSpace ;
        sh:name "SC-01 — DesignSpace vereist HardEthicsCompliance" ;
        sh:description
            """SC-01: Elk app:DesignSpace moet een valor:HardEthicsCompliance-instantie
             hebben. Niet-onderhandelbare wettelijke verplichtingen moeten
             expliciet zijn gedocumenteerd. (S-001)""" ;
        sh:property [
            sh:path     valor:hasHardEthicsCompliance ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:class    valor:HardEthicsCompliance ;
            sh:message  "SC-01: DesignSpace.hasHardEthicsCompliance is verplicht (S-001)."
        ] .


    ###############################################################################
    # SC-02 — DesignSpace vereist SoftEthicsCommitment  (S-001)
    ###############################################################################

    valor:DesignSpaceSoftEthicsShape
        a sh:NodeShape ;
        sh:targetClass app:DesignSpace ;
        sh:name "SC-02 — DesignSpace vereist SoftEthicsCommitment" ;
        sh:description
            """SC-02: Elk app:DesignSpace moet een valor:SoftEthicsCommitment-instantie
             hebben. Een lege set aspiraties is toegestaan maar moet expliciet zijn.
             (S-001)""" ;
        sh:property [
            sh:path     valor:hasSoftEthicsCommitment ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:class    valor:SoftEthicsCommitment ;
            sh:message  "SC-02: DesignSpace.hasSoftEthicsCommitment is verplicht (S-001)."
        ] .


    ###############################################################################
    # END OF SHACL — VALOR-CORE  (v0.2)
    ###############################################################################

}
