@prefix acta:  <https://valor-ecosystem.nl/ontology/acta#> .
@prefix cover: <https://valor-ecosystem.nl/ontology/cover#> .
@prefix gufo:  <http://purl.org/nemo/gufo#> .
@prefix ufoc:  <https://valor-ecosystem.nl/ontology/ufo-c#> .
@prefix ufol:  <https://valor-ecosystem.nl/ontology/ufo-l#> .
@prefix valor: <https://valor-ecosystem.nl/ontology/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix vo:   <https://valor-ecosystem.nl/ontology/> .
# TRiG version of 00g-acta.ttl
<https://valor-ecosystem.nl/ontology/acta> {
    ###############################################################################
    #  VALOR-O — Module 00g: ACTA Transactieontologie
    #
    #  Namespace  : https://valor-ecosystem.nl/ontology/acta#  (prefix acta:)
    #  Versie     : 0.6  (maart 2026)
    #  Imports    : 00a-gufo-core, 00b-ufo-b, 00c-ufo-c, 00d-ufo-l, 00f-cover
    #
    #  Bron:
    #    Almeida, J.P.A., Guizzardi, G. & Falbo, R. (2013).
    #    Revisiting the DEMO Transaction Pattern with UFO. EEWC 2013.
    #    Dietz, J.L.G. & Mulder, H.B.F. (2020).
    #    Enterprise Ontology: The DEMO Methodology. Springer.
    #
    #  Correcties v0.3:
    #    (1) gufo:ontoumlStereotype -> valor:ontoumlStereotype (DD-002)
    #    (2) rdf:type gufo:RelationshipType verwijderd van TransactorRole,
    #        Transaction, TransactionKindStep (DD-049)
    #    (3) CoordinationAct-subtypen: rdf:type gufo:SubKind -> gufo:EventType (DD-049)
    #    (4) CoordinationFact-subtypen + PositiveResult/NegativeResult:
    #        rdf:type gufo:Phase -> gufo:SituationType (DD-050)
    #    (5) PublicServiceTransaction, InternalTransaction:
    #        rdf:type gufo:SubKind -> rdf:type acta:TransactionCategory (DD-047 rev.)
    #    (6) Higher-Order Types toegevoegd: TransactionType, TransactionCategory
    #    (7) O/I/D-lagen toegevoegd (DD-048)
    #
    #  Correcties v0.4:
    #    (8) @prefix valor: namespace gecorrigeerd (DD-002)
    #    (9) ActorRole, TransactionRole: rdfs:subClassOf ufoc:Agent (DD-049)
    #   (10) stepPrecedes: rdfs:subPropertyOf gufo:contributedToTrigger verwijderd (DD-044)
    #
    #  Correcties v0.5:
    #   (11) CompositeTransactorRole: gufo:Collection + gufo:SubKind ->
    #        gufo:RoleMixin + rdfs:subClassOf ufoc:Agent. (DD-051 resolved)
    #        Rationale: CTAR is een perspectief-afhankelijk SoI-boundary-concept;
    #        anti-rigide en relationally dependent -> RoleMixin is het correcte type.
    #        Mereologisch conflict (Collection-van-Relators) is hiermee opgelost.
    #   (12) acta:TransactorNetwork toegevoegd als gufo:Collection van TransactorRoles.
    #        Scheiding van concerns: CTAR = SoI-perspectief; TransactorNetwork =
    #        context-onafhankelijke interne aggregatie. (DD-051)
    #   (13) acta:compositeHasTransactorRole verwijderd (was op CTAR; ongeldig).
    #        Vervangen door acta:representsNetwork (CTAR -> TransactorNetwork) en
    #        acta:networkHasTransactorRole (TransactorNetwork -> TransactorRole). (DD-051)
    #
    #  Structuur:
    #    §A   Transactierollen (RoleMixin)
    #    §A+  TransactorRole, InitiatorLink, AccessLink
    #    §A++ CompositeTransactorRole (RoleMixin) en TransactorNetwork (Collection)
    #    §B   Transaction + Higher-Order Types + O/I/D
    #    §C   Acts: CoordinationAct en ProductionAct
    #    §C2  CoordinationAct subtypen
    #    §C3  ProductionAct
    #    §C4  CoordinationFact
    #    §C5  TransactionKindStep
    #    §C6  ResponseLink en WaitLink
    #    §D   TransactionResult
    #    §E   Properties
    #    §F   Geneste transacties
    ###############################################################################
    
    
    vo:acta
        a owl:Ontology ;
        rdfs:label "VALOR-O Module 00g — ACTA Transactieontologie"@nl ;
        owl:imports <https://valor-ecosystem.nl/ontology/gufo-core> ;
        owl:imports <https://valor-ecosystem.nl/ontology/ufo-b> ;
        owl:imports <https://valor-ecosystem.nl/ontology/ufo-c> ;
        owl:imports <https://valor-ecosystem.nl/ontology/ufo-l> ;
        owl:imports <https://valor-ecosystem.nl/ontology/cover> ;
        owl:imports <https://valor-ecosystem.nl/ontology/tessera> ;
        owl:versionInfo "0.6" ;
        rdfs:comment
            "Formaliseert het DEMO Complete Transaction Pattern in UFO, conform Almeida et al. (EEWC 2013). v0.5: CTAR als RoleMixin; TransactorNetwork als Collection (zie versiehistorie)."@nl .
    
    
    ###############################################################################
    #  §A — Transactierollen (RoleMixin)
    ###############################################################################
    
    acta:TransactionRole
        a owl:Class ;
        rdf:type gufo:RoleMixin ;
        valor:ontoumlStereotype "roleMixin" ;
        rdfs:subClassOf ufoc:Agent ;
        rdfs:label "TransactionRole"@en , "Transactierol"@nl ;
        rdfs:comment "Overkoepelende RoleMixin voor deelnemers aan een transactie. Conform Almeida et al. (2013). (DD-040)"@nl .
    
    acta:ActorRole
        a owl:Class ;
        rdf:type gufo:RoleMixin ;
        valor:ontoumlStereotype "roleMixin" ;
        rdfs:subClassOf ufoc:Agent ;
        rdfs:label "ActorRole"@en , "Actorrol"@nl ;
        rdfs:comment "De transactie-onafhankelijke rol van een agent in de organisatie. DEMO SL §3.1: AR{digit}. (DD-045)"@nl .
    
    acta:Initiator
        a owl:Class ;
        rdf:type gufo:RoleMixin ;
        valor:ontoumlStereotype "roleMixin" ;
        rdfs:subClassOf acta:TransactionRole ;
        rdfs:subClassOf acta:ActorRole ;
        rdfs:label "Initiator"@en , "Initiator"@nl ;
        rdfs:comment "Performer van: rq, ac, rj, rv(rq/ac). Conform DEMO. (DD-040)"@nl .
    
    acta:Executor
        a owl:Class ;
        rdf:type gufo:RoleMixin ;
        valor:ontoumlStereotype "roleMixin" ;
        rdfs:subClassOf acta:TransactionRole ;
        rdfs:subClassOf acta:ActorRole ;
        rdfs:label "Executor"@en , "Uitvoerder"@nl ;
        rdfs:comment "Performer van: pm, da, dc, rv(pm/da). Conform DEMO. (DD-040)"@nl .
    
    
    ###############################################################################
    #  §A+ — TransactorRole (normatieve executor-koppeling)
    ###############################################################################
    
    acta:TransactorRole
        a owl:Class ;
        valor:ontoumlStereotype "relator" ;
        rdfs:subClassOf ufoc:SocialRelator ;
        rdfs:label "TransactorRole"@en , "Transactorrol"@nl ;
        rdfs:comment "Normatieve koppeling ActorRole ↔ Transaction (executor-positie). DEMO SL §3.1: TAR{digit}. (DD-045, DD-049)"@nl .
    
    acta:transactorActorRole
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:subPropertyOf gufo:mediates ;
        rdfs:label "transactor actor role"@en ;
        rdfs:domain acta:TransactorRole ;
        rdfs:range  acta:ActorRole ;
        rdfs:comment "De ActorRole die de executor-positie inneemt. (DD-045)"@nl .
    
    acta:transactorTransaction
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:subPropertyOf gufo:mediates ;
        rdfs:label "transactor transaction"@en ;
        rdfs:domain acta:TransactorRole ;
        rdfs:range  acta:Transaction ;
        rdfs:comment "De Transaction waarvan deze actor via de TAR executor is. (DD-045)"@nl .
    
    
    ###############################################################################
    #  §A+ — InitiatorLink en AccessLink
    ###############################################################################
    
    acta:InitiatorLink
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf gufo:Situation ;
        rdfs:label "InitiatorLink"@en , "Initiatorkoppeling"@nl ;
        rdfs:comment "Situation: ActorRole is initiator van een Transaction. DEMO SL §3.1. (DD-045)"@nl .
    
    acta:initiatorLinkRole
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "initiator link role"@en ;
        rdfs:domain acta:InitiatorLink ;
        rdfs:range  acta:ActorRole ;
        rdfs:comment "De ActorRole die initiator is. (DD-045)"@nl .
    
    acta:initiatorLinkTransaction
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "initiator link transaction"@en ;
        rdfs:domain acta:InitiatorLink ;
        rdfs:range  acta:Transaction ;
        rdfs:comment "De Transaction waarvoor deze ActorRole initiator is. (DD-045)"@nl .
    
    acta:AccessLink
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf gufo:Situation ;
        rdfs:label "AccessLink"@en , "Toegangskoppeling"@nl ;
        rdfs:comment "Situation: ActorRole heeft leestoegang tot een Transaction-bank. DEMO SL §3.1. (DD-045)"@nl .
    
    acta:accessRole
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "access role"@en ;
        rdfs:domain acta:AccessLink ;
        rdfs:range  acta:ActorRole ;
        rdfs:comment "De ActorRole met leestoegang. (DD-045)"@nl .
    
    acta:accessTransaction
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "access transaction"@en ;
        rdfs:domain acta:AccessLink ;
        rdfs:range  acta:Transaction ;
        rdfs:comment "De Transaction-bank waartoe toegang bestaat. (DD-045)"@nl .
    
    
    ###############################################################################
    #  §A++ — CompositeTransactorRole (CTAR) en TransactorNetwork
    #
    #  CORRECTIE v0.5: CTAR hergemodelleerd als gufo:RoleMixin (DD-051 resolved).
    #
    #  Probleemstelling (was DD-051 open):
    #    v0.4: CTAR als gufo:Collection + gufo:SubKind. Conflict:
    #      (a) gufo:Collection is subklasse van gufo:Object (independent endurant)
    #      (b) leden zijn TransactorRoles (gufo:Relator = existentially dependent)
    #      -> Collection van existentieel-afhankelijke entiteiten is mereologisch
    #         inconsistent als Object.
    #
    #  Oplossing: scheiding van twee concerns:
    #
    #  CTAR (RoleMixin) — het SoI-boundary-perspectief
    #    Anti-rigide: hetzelfde extern netwerk is een CTAR uitsluitend vanuit
    #    deze SoI; vanuit de externe organisatie zijn het gewone TransactorRoles.
    #    Relationally dependent: de classificatie vereist een relationele context
    #    (de interne transacties van de SoI).
    #    Conform DEMO SL §3.1: "the cut-off upper part is represented by a
    #    composite transactor role" — expliciete representatiekeuze, niet absolute
    #    aggregatie.
    #
    #  TransactorNetwork (Collection) — de context-onafhankelijke aggregatie
    #    Het concrete netwerk van TransactorRoles als gufo:Collection.
    #    Context-onafhankelijk: toegankelijk vanuit andere contexten (externe
    #    organisatie) zonder afhankelijkheid van de CTAR-classificatie.
    #    Weak Supplementation: minimaal 2 leden (SHACL G-TN).
    ###############################################################################
    
    acta:CompositeTransactorRole
        a owl:Class ;
        rdf:type gufo:RoleMixin ;
        valor:ontoumlStereotype "roleMixin" ;
        rdfs:subClassOf ufoc:Agent ;
        rdfs:label "CompositeTransactorRole"@en , "Samengestelde transactorrol"@nl ;
        rdfs:comment
            """Vanuit de SoI-grens: de rol die een extern netwerk van gelinkte
             transactorrollen speelt t.o.v. de interne transacties.
             DEMO SL §3.1: CTAR{digit}. Anti-rigide (perspectief-afhankelijk):
             hetzelfde netwerk is in een andere SoI-context afzonderlijke rollen.
             Intern detail optioneel via acta:representsNetwork -> acta:TransactorNetwork.
             (DD-051)"""@nl .
    
    acta:representsNetwork
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "represents network"@en , "vertegenwoordigt netwerk"@nl ;
        rdfs:domain acta:CompositeTransactorRole ;
        rdfs:range  acta:TransactorNetwork ;
        rdfs:comment
            """Optionele koppeling CTAR -> TransactorNetwork. Wanneer de externe
             organisatiecontext relevant is, bereikbaar via het TransactorNetwork.
             Niet verplicht: een CTAR is geldig zonder intern detail. (DD-051)"""@nl .
    
    
    acta:TransactorNetwork
        a owl:Class ;
        rdf:type gufo:CollectionType ;
        valor:ontoumlStereotype "collective" ;
        rdfs:subClassOf gufo:Collection ;
        rdfs:label "TransactorNetwork"@en , "Transactornetwerk"@nl ;
        rdfs:comment
            """Context-onafhankelijke aggregatie van onderling verbonden
             TransactorRoles. gufo:Collection: leden spelen dezelfde
             lidmaatschapsrol. Weak Supplementation: minimaal 2 leden (SHACL G-TN).
             Bruikbaar zonder CTAR-classificatie vanuit externe organisatiecontext.
             (DD-051)"""@nl .
    
    acta:networkHasTransactorRole
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "memberOf" ;
        rdfs:subPropertyOf gufo:hasProperPart ;
        rdfs:label "network has transactor role"@en , "netwerk heeft transactorrol"@nl ;
        rdfs:domain acta:TransactorNetwork ;
        rdfs:range  acta:TransactorRole ;
        rdfs:comment "Lidmaatschap van TransactorRoles in dit netwerk. Minimaal 2 via SHACL G-TN. (DD-051)"@nl .
    
    
    ###############################################################################
    #  §B — Transaction (SocialRelator) + Higher-Order Types + O/I/D-lagen
    ###############################################################################
    
    acta:Transaction
        a owl:Class ;
        valor:ontoumlStereotype "relator" ;
        rdfs:subClassOf ufoc:SocialRelator ;
        rdfs:label "Transaction"@en , "Transactie"@nl ;
        rdfs:comment
            """Normatieve interactiestructuur Initiator <-> Executor als ufoc:SocialRelator.
             Conform Almeida et al. (2013). (DD-040, DD-049)"""@nl .
    
    acta:TransactionType
        a owl:Class ;
        rdfs:subClassOf gufo:SubKind ;
        gufo:partitions acta:Transaction ;
        rdfs:label "TransactionType"@en , "Transactietype (O/I/D)"@nl ;
        rdfs:comment "Higher-Order Type voor sortale O/I/D-classificatie. (DD-048)"@nl .
    
    acta:OriginalTransaction
        a owl:Class ;
        rdf:type acta:TransactionType ;
        rdfs:subClassOf acta:Transaction ;
        rdfs:label "OriginalTransaction"@en , "Originele transactie"@nl ;
        owl:disjointWith acta:InformationalTransaction , acta:DocumentalTransaction ;
        rdfs:comment "DEMO O-laag: primair resultaat. (DD-048)"@nl .
    
    acta:InformationalTransaction
        a owl:Class ;
        rdf:type acta:TransactionType ;
        rdfs:subClassOf acta:Transaction ;
        rdfs:label "InformationalTransaction"@en , "Informationele transactie"@nl ;
        owl:disjointWith acta:OriginalTransaction , acta:DocumentalTransaction ;
        rdfs:comment "DEMO I-laag: informatie t.o.v. O-laag. (DD-048)"@nl .
    
    acta:DocumentalTransaction
        a owl:Class ;
        rdf:type acta:TransactionType ;
        rdfs:subClassOf acta:Transaction ;
        rdfs:label "DocumentalTransaction"@en , "Documentale transactie"@nl ;
        owl:disjointWith acta:OriginalTransaction , acta:InformationalTransaction ;
        rdfs:comment "DEMO D-laag: documenten/registraties. (DD-048)"@nl .
    
    acta:TransactionCategory
        a owl:Class ;
        rdfs:subClassOf gufo:Category ;
        gufo:categorizes acta:Transaction ;
        rdfs:label "TransactionCategory"@en , "Transactiecategorie"@nl ;
        rdfs:comment "Higher-Order Type voor non-sortale categorisatie. (DD-047)"@nl .
    
    acta:PublicServiceTransaction
        a owl:Class ;
        rdf:type acta:TransactionCategory ;
        rdfs:subClassOf acta:Transaction ;
        rdfs:label "PublicServiceTransaction"@en , "Publieke-diensttransactie"@nl ;
        rdfs:comment "Burger (Initiator) -> overheid (Executor). (DD-040, DD-047)"@nl .
    
    acta:InternalTransaction
        a owl:Class ;
        rdf:type acta:TransactionCategory ;
        rdfs:subClassOf acta:Transaction ;
        rdfs:label "InternalTransaction"@en , "Interne transactie"@nl ;
        rdfs:comment "Transactie binnen dezelfde organisatie. DEMO B-organisatie. (DD-040, DD-047)"@nl .
    
    
    ###############################################################################
    #  §C — CoordinationAct
    ###############################################################################
    
    acta:CoordinationAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf gufo:Action ;
        rdfs:label "CoordinationAct"@en , "Coordinatie-act"@nl ;
        rdfs:comment "Intentionele actie in de coordinatiewereld van een transactie. Conform DEMO CTP. (DD-040)"@nl .
    
    
    ###############################################################################
    #  §C2 — CoordinationAct subtypen (alle 9 DEMO SL §2.1 C-acts)
    #  rdf:type gufo:EventType (was gufo:SubKind — DD-049)
    ###############################################################################
    
    acta:RequestAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:CoordinationAct ;
        rdfs:label "RequestAct"@en , "Aanvraag-act"@nl ;
        rdfs:comment "Initiator vraagt Executor. Start CTP. [TKi/rq]. (DD-040, DD-049)"@nl .
    
    acta:PromiseAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:CoordinationAct ;
        rdfs:label "PromiseAct"@en , "Toezegging-act"@nl ;
        rdfs:comment "Executor zegt toe. [TKi/pm]. (DD-040, DD-049)"@nl .
    
    acta:DeclareAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:CoordinationAct ;
        rdfs:label "DeclareAct"@en , "Declaratie-act"@nl ;
        rdfs:comment "Executor declareert ProductionAct gereed. [TKi/da]. (DD-043, DD-049)"@nl .
    
    acta:AcceptAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:CoordinationAct ;
        rdfs:label "AcceptAct"@en , "Bekrachtiging-act"@nl ;
        rdfs:comment "Initiator bekrachtigt resultaat. [TKi/ac]. (DD-040, DD-049)"@nl .
    
    acta:DeclineAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:CoordinationAct ;
        rdfs:label "DeclineAct"@en , "Weigering-act"@nl ;
        rdfs:comment "Executor weigert voor PromiseAct. [TKi/dc]. (DD-043, DD-049)"@nl .
    
    acta:RejectAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:CoordinationAct ;
        rdfs:label "RejectAct"@en , "Verwerpings-act"@nl ;
        rdfs:comment "Initiator verwerpt gedeclareerd resultaat. [TKi/rj]. (DD-043, DD-049)"@nl .
    
    acta:RevokeAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:CoordinationAct ;
        rdfs:label "RevokeAct"@en , "Herroepings-act"@nl ;
        rdfs:comment "Actor herroept eerder uitgevoerde act. [TKi/rv]. (DD-043, DD-049)"@nl .
    
    acta:RevokeRequestAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:RevokeAct ;
        rdfs:label "RevokeRequestAct"@en , "Intrekking aanvraag"@nl ;
        rdfs:comment "Initiator herroept RequestAct. (DD-043, DD-049)"@nl .
    
    acta:RevokePromiseAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:RevokeAct ;
        rdfs:label "RevokePromiseAct"@en , "Herroeping toezegging"@nl ;
        rdfs:comment "Executor herroept PromiseAct. (DD-043, DD-049)"@nl .
    
    acta:RevokeDeclareAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:RevokeAct ;
        rdfs:label "RevokeDeclareAct"@en , "Herroeping declaratie"@nl ;
        rdfs:comment "Executor herroept DeclareAct voor accept of reject. (DD-043, DD-049)"@nl .
    
    acta:RevokeAcceptAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:RevokeAct ;
        rdfs:label "RevokeAcceptAct"@en , "Herroeping acceptatie"@nl ;
        rdfs:comment "Initiator herroept AcceptAct. (DD-043, DD-049)"@nl .
    
    acta:AllowAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:CoordinationAct ;
        rdfs:label "AllowAct"@en , "Toestemmings-act"@nl ;
        rdfs:comment "Addressee staat RevokeAct toe. [TKi/al]. (DD-043, DD-049)"@nl .
    
    acta:RefuseAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf acta:CoordinationAct ;
        rdfs:label "RefuseAct"@en , "Weigerings-act (herroeping)"@nl ;
        rdfs:comment "Addressee weigert RevokeAct. [TKi/rf]. (DD-043, DD-049)"@nl .
    
    
    ###############################################################################
    #  §C3 — ProductionAct
    ###############################################################################
    
    acta:ProductionAct
        a owl:Class ;
        rdf:type gufo:EventType ;
        valor:ontoumlStereotype "event" ;
        rdfs:subClassOf gufo:Action ;
        rdfs:label "ProductionAct"@en , "Productie-act"@nl ;
        rdfs:comment "Brengt het TransactionResult voort. Performer: Executor. DEMO CTP fase 3. (DD-041)"@nl .
    
    
    ###############################################################################
    #  §C4 — CoordinationFact
    #  rdf:type gufo:SituationType (was gufo:Phase — DD-050)
    ###############################################################################
    
    acta:CoordinationFact
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf gufo:Situation ;
        rdfs:label "CoordinationFact"@en , "Coordinatiefeit"@nl ;
        rdfs:comment "Informationele toestand na uitvoering van een CoordinationAct. Negen disjuncte subtypen. (DD-044)"@nl .
    
    acta:RequestedFact
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf acta:CoordinationFact ;
        rdfs:label "RequestedFact"@en , "Aangevraagd"@nl ;
        rdfs:comment "DEMO: (TKi/rq). (DD-044, DD-050)"@nl .
    
    acta:PromisedFact
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf acta:CoordinationFact ;
        rdfs:label "PromisedFact"@en , "Toegezegd"@nl ;
        rdfs:comment "DEMO: (TKi/pm). (DD-044, DD-050)"@nl .
    
    acta:DeclaredFact
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf acta:CoordinationFact ;
        rdfs:label "DeclaredFact"@en , "Gedeclareerd"@nl ;
        rdfs:comment "DEMO: (TKi/da). (DD-044, DD-050)"@nl .
    
    acta:AcceptedFact
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf acta:CoordinationFact ;
        rdfs:label "AcceptedFact"@en , "Geaccepteerd"@nl ;
        rdfs:comment "Transactie voltooid. DEMO: (TKi/ac). (DD-044, DD-050)"@nl .
    
    acta:DeclinedFact
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf acta:CoordinationFact ;
        rdfs:label "DeclinedFact"@en , "Geweigerd"@nl ;
        rdfs:comment "DEMO: (TKi/dc). (DD-044, DD-050)"@nl .
    
    acta:RejectedFact
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf acta:CoordinationFact ;
        rdfs:label "RejectedFact"@en , "Verworpen"@nl ;
        rdfs:comment "Opent bezwaarpad. DEMO: (TKi/rj). (DD-044, DD-050)"@nl .
    
    acta:RevokedFact
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf acta:CoordinationFact ;
        rdfs:label "RevokedFact"@en , "Herroepen"@nl ;
        rdfs:comment "Wacht op Allow/Refuse. DEMO: (TKi/rv). (DD-044, DD-050)"@nl .
    
    acta:AllowedFact
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf acta:CoordinationFact ;
        rdfs:label "AllowedFact"@en , "Herroeping toegestaan"@nl ;
        rdfs:comment "DEMO: (TKi/al). (DD-044, DD-050)"@nl .
    
    acta:RefusedFact
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf acta:CoordinationFact ;
        rdfs:label "RefusedFact"@en , "Herroeping geweigerd"@nl ;
        rdfs:comment "DEMO: (TKi/rf). (DD-044, DD-050)"@nl .
    
    [ a owl:AllDisjointClasses ;
      owl:members (
        acta:RequestedFact  acta:PromisedFact   acta:DeclaredFact
        acta:AcceptedFact   acta:DeclinedFact   acta:RejectedFact
        acta:RevokedFact    acta:AllowedFact    acta:RefusedFact
      )
    ] .
    
    acta:broughtAboutFact
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "creation" ;
        rdfs:subPropertyOf gufo:broughtAbout ;
        rdfs:label "brought about fact"@en , "brengt feit voort"@nl ;
        rdfs:domain acta:CoordinationAct ;
        rdfs:range  acta:CoordinationFact ;
        rdfs:comment "De CoordinationFact voortgebracht door deze act. (SHACL G-F2; DD-044)"@nl .
    
    
    ###############################################################################
    #  §C5 — TransactionKindStep
    #  rdf:type gufo:RelationshipType verwijderd (DD-049)
    ###############################################################################
    
    acta:TransactionKindStep
        a owl:Class ;
        valor:ontoumlStereotype "relator" ;
        rdfs:subClassOf gufo:Relator ;
        rdfs:label "TransactionKindStep"@en , "Transactiestap"@nl ;
        rdfs:comment "Paar (Transaction-instantie x CoordinationFact-type). DEMO: '(TK01/rq) in TX-001'. (DD-044, DD-049)"@nl .
    
    acta:inTransaction
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:subPropertyOf gufo:mediates ;
        rdfs:label "in transaction"@en ;
        rdfs:domain acta:TransactionKindStep ;
        rdfs:range  acta:Transaction ;
        rdfs:comment "De Transaction-instantie. (DD-044)"@nl .
    
    acta:ofFactKind
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:subPropertyOf gufo:mediates ;
        rdfs:label "of fact kind"@en ;
        rdfs:domain acta:TransactionKindStep ;
        rdfs:range  acta:CoordinationFact ;
        rdfs:comment "Het CoordinationFact-type. (DD-044)"@nl .
    
    acta:stepPrecedes
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "step precedes"@en ;
        rdfs:domain acta:TransactionKindStep ;
        rdfs:range  acta:TransactionKindStep ;
        rdfs:comment "Logische precedentie Relator -> Relator. [v0.4] gufo:contributedToTrigger superproperty verwijderd (domain/range conflict). (DD-044)"@nl .
    
    
    ###############################################################################
    #  §C6 — ResponseLink en WaitLink
    ###############################################################################
    
    acta:ResponseLink
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf gufo:Situation ;
        rdfs:label "ResponseLink"@en , "Responsekoppeling"@nl ;
        rdfs:comment "C-fact in TX-A triggert act in TX-B. DEMO SL §4.1. (DD-046)"@nl .
    
    acta:fromStep
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "from step"@en ;
        rdfs:domain acta:ResponseLink ;
        rdfs:range  acta:TransactionKindStep ;
        rdfs:comment "Triggerende TransactionKindStep. (DD-046)"@nl .
    
    acta:toStep
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "to step"@en ;
        rdfs:domain acta:ResponseLink ;
        rdfs:range  acta:TransactionKindStep ;
        rdfs:comment "Getriggerde TransactionKindStep. (DD-046)"@nl .
    
    acta:WaitLink
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf gufo:Situation ;
        rdfs:label "WaitLink"@en , "Wachtkoppeling"@nl ;
        rdfs:comment "ActorRole wacht op TransactionKindStep. DEMO SL §3.1. (DD-046)"@nl .
    
    acta:waitingRole
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "waiting role"@en ;
        rdfs:domain acta:WaitLink ;
        rdfs:range  acta:ActorRole ;
        rdfs:comment "De ActorRole waarvan de actoren wachten. (DD-046)"@nl .
    
    acta:awaitedStep
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "awaited step"@en ;
        rdfs:domain acta:WaitLink ;
        rdfs:range  acta:TransactionKindStep ;
        rdfs:comment "De TransactionKindStep waarop gewacht wordt. (DD-046)"@nl .
    
    
    ###############################################################################
    #  §D — TransactionResult
    #  rdf:type gufo:SituationType (was gufo:Phase — DD-050)
    ###############################################################################
    
    acta:TransactionResult
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf gufo:Situation ;
        rdfs:label "TransactionResult"@en , "Transactieresultaat"@nl ;
        rdfs:comment "Toestand voortgebracht door ProductionAct. Tevens cover:ValueObject voor Axia-brug. (DD-042)"@nl .
    
    acta:PositiveResult
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf acta:TransactionResult ;
        rdfs:label "PositiveResult"@en , "Positief resultaat"@nl ;
        rdfs:comment "Initiator verkrijgt gevraagd resultaat. Schept typisch ufol:ClaimRightRelator. (DD-041, DD-050)"@nl .
    
    acta:NegativeResult
        a owl:Class ;
        rdf:type gufo:SituationType ;
        valor:ontoumlStereotype "situation" ;
        rdfs:subClassOf acta:TransactionResult ;
        rdfs:label "NegativeResult"@en , "Negatief resultaat"@nl ;
        rdfs:comment "Initiator verkrijgt gevraagd resultaat niet. Opent bezwaarpad. (DD-041, DD-050)"@nl .
    
    
    ###############################################################################
    #  §E — Properties
    ###############################################################################
    
    acta:hasInitiator
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:subPropertyOf gufo:mediates ;
        rdfs:label "has initiator"@en ;
        rdfs:domain acta:Transaction ;
        rdfs:range  ufoc:Agent ;
        rdfs:comment "Convenience shortcut; rijkere structuur via InitiatorLink. (DD-040)"@nl .
    
    acta:hasExecutor
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:subPropertyOf gufo:mediates ;
        rdfs:label "has executor"@en ;
        rdfs:domain acta:Transaction ;
        rdfs:range  ufoc:Agent ;
        rdfs:comment "Convenience shortcut; rijkere structuur via TransactorRole. (DD-040)"@nl .
    
    acta:comprisesAct
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "componentOf" ;
        rdfs:subPropertyOf gufo:hasProperPart ;
        rdfs:label "comprises act"@en ;
        rdfs:domain acta:Transaction ;
        rdfs:range  gufo:Action ;
        rdfs:comment "De acts die deel uitmaken van deze transactie. (DD-040)"@nl .
    
    acta:hasTransactionResult
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "creation" ;
        rdfs:label "has transaction result"@en ;
        rdfs:domain acta:Transaction ;
        rdfs:range  acta:TransactionResult ;
        rdfs:comment "Het TransactionResult voortgebracht door de ProductionAct. (DD-041, DD-042)"@nl .
    
    acta:groundedIn
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "grounded in"@en ;
        rdfs:domain acta:Transaction ;
        rdfs:range  ufol:LegalRelator ;
        rdfs:comment "Pre-existente LegalRelator die de transactie juridisch mogelijk maakt. (DD-040)"@nl .
    
    acta:guidedByPolicy
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "guided by policy"@en ;
        rdfs:domain acta:Transaction ;
        rdfs:range  ufol:Policy ;
        rdfs:comment "De Policy die de Executor stuurt. (DD-040)"@nl .
    
    acta:createsLegalRelator
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "creation" ;
        rdfs:label "creates legal relator"@en ;
        rdfs:domain acta:ProductionAct ;
        rdfs:range  ufol:LegalRelator ;
        rdfs:comment "Nieuwe LegalRelator voortgebracht door ProductionAct. (DD-041)"@nl .
    
    acta:isProductionActOf
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "componentOf" ;
        rdfs:subPropertyOf gufo:isPartOf ;
        rdfs:label "is production act of"@en ;
        rdfs:domain acta:ProductionAct ;
        rdfs:range  acta:Transaction ;
        rdfs:comment "De transactie waarvan deze ProductionAct de kern vormt. (DD-040)"@nl .
    
    acta:precedes
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "precedes"@en ;
        rdfs:domain gufo:Action ;
        rdfs:range  gufo:Action ;
        rdfs:comment "Logische precedentie tussen acts in het CTP. (DD-040)"@nl .
    
    acta:performedBy
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "participational" ;
        rdfs:subPropertyOf gufo:hasParticipant ;
        rdfs:label "performed by"@en ;
        rdfs:domain gufo:Action ;
        rdfs:range  ufoc:Agent ;
        rdfs:comment "De agent die de act uitvoert. (DD-040)"@nl .
    
    acta:enablesExperience
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "enables experience"@en ;
        rdfs:domain acta:TransactionResult ;
        rdfs:range  cover:ValueExperience ;
        rdfs:comment "ValueExperiences die dit TransactionResult mogelijk maakt. Brug Acta <-> Axia. (DD-042)"@nl .
    
    
    ###############################################################################
    #  §F — Geneste transacties
    ###############################################################################
    
    acta:requiresTransaction
        a owl:ObjectProperty ;
        valor:ontoumlStereotype "mediation" ;
        rdfs:label "requires transaction"@en ;
        rdfs:domain acta:Transaction ;
        rdfs:range  acta:Transaction ;
        rdfs:comment "Sub-transactie vereist voor voltooiing. Conform DEMO B-organisatie. (DD-040)"@nl .
    
    ###############################################################################
    #  Einde module 00g-acta.trig (v0.6)
    ###############################################################################
}
