@prefix causa: <https://valor-ecosystem.nl/ontology/causa#> .
@prefix gufo:  <http://purl.org/nemo/gufo#> .
@prefix ufob:  <https://valor-ecosystem.nl/ontology/ufo-b#> .
@prefix ufoc:  <https://valor-ecosystem.nl/ontology/ufo-c#> .
@prefix valor: <https://valor-ecosystem.nl/ontology/> .
@prefix app:   <https://valor-ecosystem.nl/ontology/application#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix vo:    <https://valor-ecosystem.nl/ontology/> .
# TRiG version of 00h-causa.trig
<https://valor-ecosystem.nl/ontology/causa> {
###############################################################################
#  VALOR-O — Module 00h: CAUSA Causal Loop Diagram Ontologie
#
#  Namespace  : https://valor-ecosystem.nl/ontology/causa#  (prefix causa:)
#  Versie     : 0.2  (maart 2026)
#  Imports    : 00a-gufo-core, 00b-ufo-b, 00c-ufo-c, 00j-tessera, 00k-application
#
#  Wijzigingen t.o.v. v0.1 (DD-061, DD-062, DD-064, DD-065):
#
#   [C-001] valor:Issue VERWIJDERD uit deze module (DD-062)
#           Verplaatst naar 00k-application als top-level toepassingsconcept
#           dat door alle perspectieven wordt gedeeld.
#
#   [C-002] causa:CausalClaim: rdfs:subClassOf valor:Tessera TOEGEVOEGD (DD-061)
#           Erft: valor:epistemicStatus (5-waardig), valor:claimedBy,
#           valor:claimedAt, valor:claimType, valor:inPhase, valor:hasEvidence,
#           argumentatierelaties (supports/undermines/qualifies/presupposes).
#
#   [C-003] causa:EpistemicStatus + instanties DEPRECATED (DD-064, DD-065)
#           Vervangen door valor:EpistemicStatus uit 00j-tessera.
#
#   [C-004] causa:Evidence, causa:EvidenceType DEPRECATED (DD-061)
#           Vervangen door valor:Evidence en valor:EvidenceType uit 00j-tessera.
#
#   [C-005] causa:modelEpistemicStatus type gewijzigd naar valor:EpistemicStatus
#
#  Bron:
#    Forrester (1961), Meadows (2008), Sterman (2000),
#    Enserink et al. (2022) PAMS, Guizzardi et al. (2013) UFO-C/UFO-B.
#
#  Ontologische grondslag (DD-052):
#    Twee lagen:
#      EPISTEMISCH  — causa:CausalClaim (valor:Tessera + ufoc:Belief)
#      ONTOLOGISCH  — gufo:contributedToTrigger (de werkelijke relatie)
#
#  Structuur:
#    §B  CausalVariable
#    §C  CausalSituation
#    §D  CausalClaim (valor:Tessera subklasse)
#    §E  CausalModel
#    §F  FeedbackLoop
#    §G  Properties
#    §H  DEPRECATED v0.1-artefacten (verwijderd in v0.3)
###############################################################################


vo:causa
    a owl:Ontology ;
    rdfs:label "VALOR-O Module 00h — CAUSA Causal Loop Diagram Ontologie"@nl ;
    owl:imports <https://valor-ecosystem.nl/ontology/gufo-core> ;
    owl:imports <https://valor-ecosystem.nl/ontology/ufo-b> ;
    owl:imports <https://valor-ecosystem.nl/ontology/ufo-c> ;
    owl:imports <https://valor-ecosystem.nl/ontology/tessera> ;
    owl:imports <https://valor-ecosystem.nl/ontology/application> ;
    owl:versionInfo "0.2" ;
    owl:priorVersion "0.1" ;
    rdfs:comment
        """Formaliseert Causal Loop Diagrams in UFO. v0.2: Issue naar
         00k-application, CausalClaim subclasseert valor:Tessera,
         lokale EpistemicStatus/Evidence deprecated. (DD-052, DD-061, DD-062)"""@nl .


###############################################################################
#  §B — CausalVariable
###############################################################################

causa:CausalVariable
    a owl:Class ;
    rdf:type gufo:QualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "quality" ;
    rdfs:subClassOf gufo:Quality ;
    rdfs:label "CausalVariable"@en , "Causale variabele"@nl ;
    rdfs:comment
        """Een meetbare eigenschap van een gufo:Situation die als variabele
         in een Causal Loop Diagram fungeert. (DD-055)"""@nl .

causa:inheresInSituation
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:subPropertyOf gufo:inheresIn ;
    rdfs:label "inheres in situation"@en , "inhereert in situatie"@nl ;
    rdfs:domain causa:CausalVariable ;
    rdfs:range  gufo:Situation ;
    rdfs:comment "De Situation waarvan deze CausalVariable een eigenschap is. (DD-055)"@nl .

causa:hasMeasurementScale
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "has measurement scale"@en , "heeft meetschaal"@nl ;
    rdfs:domain causa:CausalVariable ;
    rdfs:range  causa:MeasurementScale ;
    rdfs:comment "De meetschaal van deze variabele. Optioneel (SHACL CV1 Warning). (DD-055)"@nl .

causa:MeasurementScale
    a owl:Class ;
    rdf:type gufo:NonQualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "mode" ;
    rdfs:subClassOf gufo:IntrinsicMode ;
    rdfs:label "MeasurementScale"@en , "Meetschaal"@nl ;
    rdfs:comment "De schaal waarop een CausalVariable wordt gemeten. (DD-055)"@nl .

causa:QuantitativeScale
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf causa:MeasurementScale ;
    rdfs:label "QuantitativeScale"@en , "Kwantitatieve schaal"@nl ;
    rdfs:comment "Numerieke meetschaal. (DD-055)"@nl .

causa:QualitativeScale
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf causa:MeasurementScale ;
    rdfs:label "QualitativeScale"@en , "Kwalitatieve schaal"@nl ;
    rdfs:comment "Ordinale of nominale schaal. (DD-055)"@nl .


###############################################################################
#  §C — CausalSituation
###############################################################################

causa:CausalSituation
    a owl:Class ;
    rdf:type gufo:SituationType ;
    valor:ontoumlStereotype "situation" ;
    rdfs:subClassOf gufo:Situation ;
    rdfs:label "CausalSituation"@en , "Causale situatie"@nl ;
    rdfs:comment
        """De propositionele inhoud van een CausalClaim: de mogelijke
         stand van zaken waarbij V1 V2 causaal beïnvloedt. (DD-056)"""@nl .

causa:Polarity
    a owl:Class ;
    rdf:type gufo:NonQualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "mode" ;
    rdfs:subClassOf gufo:IntrinsicMode ;
    rdfs:label "Polarity"@en , "Polariteit"@nl ;
    rdfs:comment "De richting van de causale invloed: + of -. (DD-056)"@nl .

causa:ReinforcingPolarity
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf causa:Polarity ;
    rdfs:label "ReinforcingPolarity"@en , "Versterkende polariteit (+)"@nl ;
    rdfs:comment "Toename V1 → toename V2. CLD: '+'. (DD-056)"@nl .

causa:BalancingPolarity
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf causa:Polarity ;
    rdfs:label "BalancingPolarity"@en , "Dempende polariteit (-)"@nl ;
    rdfs:comment "Toename V1 → afname V2. CLD: '-'. (DD-056)"@nl .

causa:Delay
    a owl:Class ;
    rdf:type gufo:QualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "quality" ;
    rdfs:subClassOf gufo:Quality ;
    rdfs:label "Delay"@en , "Vertraging"@nl ;
    rdfs:comment "Optionele vertraging in de causale doorwerking. CLD: '||'. (DD-056)"@nl .


###############################################################################
#  §D — CausalClaim (valor:Tessera subklasse)
#
#  DD-057, DD-061 (v0.2):
#  Erft van valor:Tessera: epistemicStatus (5-waardig), claimedBy,
#  claimedAt, claimType, inPhase, hasEvidence, argumentatierelaties.
#  Causa-specifiek: hasUncertaintyLevel, manifestsAsRelation.
###############################################################################

causa:CausalClaim
    a owl:Class ;
    rdf:type gufo:NonQualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "mode" ;
    rdfs:subClassOf valor:Tessera ;
    rdfs:label "CausalClaim"@en , "Causale claim"@nl ;
    rdfs:comment
        """Een valor:Tessera (ufoc:Belief) van een Agent over een
         causa:CausalSituation. Erft epistemische infrastructuur van
         Tessera. Causa-specifiek: hasUncertaintyLevel, manifestsAsRelation.
         Als Accepted: gufo:contributedToTrigger bestaat in ontologische laag.
         (DD-052, DD-057, DD-061)"""@nl .

causa:UncertaintyLevel
    a owl:Class ;
    rdf:type gufo:NonQualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "mode" ;
    rdfs:subClassOf gufo:IntrinsicMode ;
    rdfs:label "UncertaintyLevel"@en , "Onzekerheidsgraad"@nl ;
    rdfs:comment "PAMS-onzekerheidsgraad. (DD-059)"@nl .

causa:StatisticalRisk
    a causa:UncertaintyLevel ;
    rdfs:label "Statistical Risk"@en , "Statistisch risico"@nl ;
    rdfs:comment "Kansverdelingen bekend. (DD-059)"@nl .

causa:ScenarioUncertainty
    a causa:UncertaintyLevel ;
    rdfs:label "Scenario Uncertainty"@en , "Scenario-onzekerheid"@nl ;
    rdfs:comment "Meerdere plausibele toekomsten. (DD-059)"@nl .

causa:DeepUncertainty
    a causa:UncertaintyLevel ;
    rdfs:label "Deep Uncertainty"@en , "Diepe onzekerheid"@nl ;
    rdfs:comment "Geen overeenstemming over model of waarden. (DD-059)"@nl .


###############################################################################
#  §E — CausalModel
###############################################################################

causa:CausalModel
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf ufoc:SocialObject ;
    rdfs:label "CausalModel"@en , "Causaal model"@nl ;
    rdfs:comment
        """Een coherente collectie CausalClaims over een valor:Issue.
         Deliberatie op twee niveaus: per Claim en per Model. (DD-053)"""@nl .

causa:ExplanatoryModel
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf causa:CausalModel ;
    rdfs:label "ExplanatoryModel"@en , "Verklarend model"@nl ;
    rdfs:comment "Verklarende CausalClaims (Verkenningsfase). (DD-053)"@nl .

causa:SolutionModel
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf causa:CausalModel ;
    rdfs:label "SolutionModel"@en , "Oplossingsmodel"@nl ;
    rdfs:comment "Interventiegerichte CausalClaims (Ontwerpfase). (DD-053)"@nl .

causa:Intervention
    a owl:Class ;
    rdf:type gufo:SituationType ;
    valor:ontoumlStereotype "situation" ;
    rdfs:subClassOf gufo:Situation ;
    rdfs:label "Intervention"@en , "Interventie"@nl ;
    rdfs:comment "Een doelbewuste ingreep op een of meer CausalVariables. (DD-053)"@nl .


###############################################################################
#  §F — FeedbackLoop
###############################################################################

causa:FeedbackLoop
    a owl:Class ;
    rdf:type gufo:SituationType ;
    valor:ontoumlStereotype "situation" ;
    rdfs:subClassOf gufo:Situation ;
    rdfs:label "FeedbackLoop"@en , "Terugkoppelingsloop"@nl ;
    rdfs:comment "Cyclisch patroon van CausalClaims. Detecteerbaar via SPARQL. (DD-060)"@nl .

causa:ReinforcingLoop
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf causa:FeedbackLoop ;
    rdfs:label "ReinforcingLoop"@en , "Versterkende loop (R)"@nl ;
    rdfs:comment "Exponentiële groei of ineenstorting. CLD: 'R'. (DD-060)"@nl .

causa:BalancingLoop
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf causa:FeedbackLoop ;
    rdfs:label "BalancingLoop"@en , "Dempende loop (B)"@nl ;
    rdfs:comment "Zelfregulering of oscillatie. CLD: 'B'. (DD-060)"@nl .


###############################################################################
#  §G — Properties
###############################################################################

causa:fromVariable
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "from variable"@en ;
    rdfs:domain causa:CausalSituation ;
    rdfs:range  causa:CausalVariable ;
    rdfs:comment "De veroorzakende CausalVariable. (DD-056)"@nl .

causa:toVariable
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "to variable"@en ;
    rdfs:domain causa:CausalSituation ;
    rdfs:range  causa:CausalVariable ;
    rdfs:comment "De beïnvloede CausalVariable. (DD-056)"@nl .

causa:hasPolarity
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "has polarity"@en ;
    rdfs:domain causa:CausalSituation ;
    rdfs:range  causa:Polarity ;
    rdfs:comment "De polariteit van de causale invloed. (DD-056)"@nl .

causa:hasDelay
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "has delay"@en ;
    rdfs:domain causa:CausalSituation ;
    rdfs:range  causa:Delay ;
    rdfs:comment "Optionele vertraging. (DD-056)"@nl .

causa:hasUncertaintyLevel
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "has uncertainty level"@en ;
    rdfs:domain causa:CausalClaim ;
    rdfs:range  causa:UncertaintyLevel ;
    rdfs:comment "PAMS-onzekerheidsgraad. Causa-specifiek. (DD-059)"@nl .

causa:manifestsAsRelation
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "manifests as relation"@en ;
    rdfs:domain causa:CausalClaim ;
    rdfs:range  gufo:Situation ;
    rdfs:comment
        """Koppeling naar de werkelijke gufo:Situation (ontologische laag).
         Alleen ingevuld als valor:epistemicStatus = valor:AcceptedStatus.
         (DD-057)"""@nl .

causa:hasClaim
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "has claim"@en ;
    rdfs:domain causa:CausalModel ;
    rdfs:range  causa:CausalClaim ;
    rdfs:comment "De CausalClaims van dit model. Minimaal 1 (SHACL CM1). (DD-053)"@nl .

causa:modelEpistemicStatus
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "model epistemic status"@en ;
    rdfs:domain causa:CausalModel ;
    rdfs:range  valor:EpistemicStatus ;
    rdfs:comment "De status van het model als geheel (valor:EpistemicStatus). (DD-053, DD-064)"@nl .

causa:modelAuthor
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "model author"@en ;
    rdfs:domain causa:CausalModel ;
    rdfs:range  ufoc:Agent ;
    rdfs:comment "De auteur(s) van dit model. (DD-053)"@nl .

causa:modelCreatedAt
    a owl:DatatypeProperty ;
    rdfs:label "model created at"@en ;
    rdfs:domain causa:CausalModel ;
    rdfs:range  xsd:dateTime ;
    rdfs:comment "Aanmaaktijdstip van het model. (DD-053)"@nl .

causa:addressesIssue
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "addresses issue"@en ;
    rdfs:domain causa:CausalModel ;
    rdfs:range  valor:Issue ;
    rdfs:comment "Het Issue waarop dit model betrekking heeft. (DD-053)"@nl .

causa:loopIncludesClaim
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "loop includes claim"@en ;
    rdfs:domain causa:FeedbackLoop ;
    rdfs:range  causa:CausalClaim ;
    rdfs:comment "Claims die de cyclus vormen. Minimaal 2 (SHACL FL1). (DD-060)"@nl .


###############################################################################
#  §H — DEPRECATED v0.1-artefacten (verwijderd in v0.3)
###############################################################################

causa:EpistemicStatus
    a owl:Class ;
    owl:deprecated true ;
    rdfs:comment "DEPRECATED v0.2 (DD-064). Gebruik valor:EpistemicStatus + valor:epistemicStatus."@nl .

causa:ProposedStatus
    owl:deprecated true ;
    rdfs:comment "DEPRECATED v0.2. Gebruik valor:ProposedStatus."@nl .

causa:AcceptedStatus
    owl:deprecated true ;
    rdfs:comment "DEPRECATED v0.2. Gebruik valor:AcceptedStatus."@nl .

causa:RejectedStatus
    owl:deprecated true ;
    rdfs:comment "DEPRECATED v0.2. Gebruik valor:RejectedStatus."@nl .

causa:hasEpistemicStatus
    a owl:ObjectProperty ;
    owl:deprecated true ;
    rdfs:comment "DEPRECATED v0.2 (DD-064). Gebruik valor:epistemicStatus."@nl .

causa:Evidence
    a owl:Class ;
    owl:deprecated true ;
    rdfs:subClassOf valor:Evidence ;
    rdfs:comment "DEPRECATED v0.2 (DD-061). Gebruik valor:Evidence."@nl .

causa:EvidenceType
    a owl:Class ;
    owl:deprecated true ;
    rdfs:comment "DEPRECATED v0.2 (DD-061). Gebruik valor:EvidenceType."@nl .

causa:EmpiricalEvidence     owl:deprecated true .
causa:TheoreticalEvidence   owl:deprecated true .
causa:ExpertEvidence        owl:deprecated true .
causa:ExperientialEvidence  owl:deprecated true .

causa:groundedInEvidence
    a owl:ObjectProperty ;
    owl:deprecated true ;
    rdfs:comment "DEPRECATED v0.2 (DD-061). Gebruik valor:hasEvidence."@nl .

causa:claimedAt
    a owl:DatatypeProperty ;
    owl:deprecated true ;
    rdfs:comment "DEPRECATED v0.2 (DD-061). Gebruik valor:claimedAt."@nl .

causa:evidenceType
    a owl:ObjectProperty ;
    owl:deprecated true ;
    rdfs:comment "DEPRECATED v0.2. Gebruik valor:evidenceType."@nl .

causa:evidenceSource
    a owl:DatatypeProperty ;
    owl:deprecated true ;
    rdfs:comment "DEPRECATED v0.2. Gebruik valor:evidenceSource."@nl .

###############################################################################
#  Einde module 00h-causa.trig (v0.2)
###############################################################################
}
