# TRiG version of SOCIA ontology
<https://valor-ecosystem.nl/ontology/socia> {
###############################################################################
#  VALOR-O — Module 00i: SOCIA Actor Analysis Ontologie (i*-framework)
#
#  Namespace  : https://valor-ecosystem.nl/ontology/socia#  (prefix socia:)
#  Versie     : 0.2  (maart 2026)
#  Imports    : 00a-gufo-core, 00c-ufo-c, 00j-tessera, 00k-application
#
#  Wijzigingen t.o.v. v0.1:
#   [S-001] owl:imports causa VERVANGEN door tessera + application (DD-062)
#           valor:Issue staat nu in 00k-application. CAUSA-import niet meer nodig.
#   [S-002] socia:StakeholderClaim TOEGEVOEGD als valor:Tessera subklasse (DD-061)
#           Maakt stakeholder-beweringen (belangen, doelen, machtsverhoudingen)
#           epistemisch bevraagbaar als onderdeel van het centrale Tessera-systeem.
#   [S-003] socia:stakeholderSubmitsClaim range gewijzigd naar valor:Tessera
#           (was: causa:CausalClaim — te specifiek)
#
#  Bron:
#    Yu, E. (1995). Modelling Strategic Relationships. PhD Toronto.
#    Yu, E. (2011). Social Modeling and i*. LNCS 6520.
#    Guizzardi et al. (2013). UFO-C. [SocialCommitment als Relator]
#    Enserink et al. (2022). PAMS. [stakeholderanalyse]
#
#  Ontologische grondslag (DD-061):
#    Een i*-dependum is een specialisatie van ufoc:SocialCommitment.
#    Een socia:StakeholderClaim is een valor:Tessera over een stakeholder-
#    gerelateerde situatie (belangen, afhankelijkheden, machtsverhoudingen).
#
#  Structuur:
#    §A  Stakeholder
#    §B  StakeholderRole
#    §C  StakeholderClaim (valor:Tessera subklasse) — NIEUW v0.2
#    §D  IntentionalDependency
#    §E  DependencyType
#    §F  ActorBoundary
#    §G  StakeholderMap
#    §H  Properties
###############################################################################

@prefix socia: <https://valor-ecosystem.nl/ontology/socia#> .
@prefix gufo:  <http://purl.org/nemo/gufo#> .
@prefix ufoc:  <https://valor-ecosystem.nl/ontology/ufo-c#> .
@prefix valor: <https://valor-ecosystem.nl/ontology/> .
@prefix app:   <https://valor-ecosystem.nl/ontology/application#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix vo:    <https://valor-ecosystem.nl/ontology/> .

vo:socia
    a owl:Ontology ;
    rdfs:label "VALOR-O Module 00i — SOCIA Actor Analysis Ontologie"@nl ;
    owl:imports <https://valor-ecosystem.nl/ontology/gufo-core> ;
    owl:imports <https://valor-ecosystem.nl/ontology/ufo-c> ;
    owl:imports <https://valor-ecosystem.nl/ontology/tessera> ;
    owl:imports <https://valor-ecosystem.nl/ontology/application> ;
    owl:versionInfo "0.2" ;
    owl:priorVersion "0.1" ;
    rdfs:comment
        """Formaliseert het i*-framework in UFO. v0.2: import causa vervangen
         door tessera + application; StakeholderClaim toegevoegd als
         valor:Tessera subklasse. (DD-061, DD-062)"""@nl .


###############################################################################
#  §A — Stakeholder
###############################################################################

socia:Stakeholder
    a owl:Class ;
    rdf:type gufo:RoleMixin ;
    valor:ontoumlStereotype "roleMixin" ;
    rdfs:subClassOf ufoc:Agent ;
    rdfs:label "Stakeholder"@en , "Belanghebbende"@nl ;
    rdfs:comment
        """Een Agent met intentionele modi relevant voor een valor:Issue.
         Anti-rigide: stakeholderrol is Issue- en context-afhankelijk.
         Conform i*: 'actor with an intentional boundary'. (DD-061)"""@nl .

socia:HumanStakeholder
    a owl:Class ;
    rdf:type gufo:Role ;
    valor:ontoumlStereotype "role" ;
    rdfs:subClassOf socia:Stakeholder ;
    rdfs:subClassOf ufoc:PhysicalAgent ;
    rdfs:label "HumanStakeholder"@en , "Menselijke belanghebbende"@nl ;
    rdfs:comment "Een fysieke persoon als Stakeholder bij een Issue. (DD-061)"@nl .

socia:OrganisationalActor
    a owl:Class ;
    rdf:type gufo:Role ;
    valor:ontoumlStereotype "role" ;
    rdfs:subClassOf socia:Stakeholder ;
    rdfs:subClassOf ufoc:InstitutionalAgent ;
    rdfs:label "OrganisationalActor"@en , "Organisationele actor"@nl ;
    rdfs:comment "Een institutionele agent als Stakeholder bij een Issue. (DD-061)"@nl .


###############################################################################
#  §B — StakeholderRole + InterestProfile
###############################################################################

socia:StakeholderRole
    a owl:Class ;
    rdf:type gufo:Role ;
    valor:ontoumlStereotype "role" ;
    rdfs:subClassOf ufoc:SocialRole ;
    rdfs:label "StakeholderRole"@en , "Stakeholderrol"@nl ;
    rdfs:comment
        """De functionele positie van een Stakeholder t.o.v. een Issue.
         Voorbeelden: aanvrager, uitvoerder, toezichthouder, ketenpartner.
         (DD-062)"""@nl .

socia:StakeholderInterestProfile
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf ufoc:SocialObject ;
    rdfs:label "StakeholderInterestProfile"@en , "Belangenprofiel"@nl ;
    rdfs:comment
        """Een coherente verzameling intentionele modi (Goals, Interests,
         Concerns, Beliefs) van een Stakeholder t.o.v. een Issue. (DD-062)"""@nl .


###############################################################################
#  §C — StakeholderClaim (valor:Tessera subklasse) — NIEUW v0.2
#
#  Een StakeholderClaim is een bewering over een stakeholder-gerelateerde
#  situatie: een belang, een doel, een machtspositie, of een afhankelijkheid.
#  Door valor:Tessera te subclasseeren erft StakeholderClaim de volledige
#  epistemische infrastructuur: status, bewijs, argumentatierelaties.
#
#  Drie subtypen:
#    InterestClaim    — bewering over een belang of concern
#    GoalClaim        — bewering over een doel of intentie
#    PowerClaim       — bewering over een machtspositie of invloedrelatie
###############################################################################

socia:StakeholderClaim
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf valor:Tessera ;
    rdfs:label "StakeholderClaim"@en , "Stakeholder-claim"@nl ;
    rdfs:comment
        """Een valor:Tessera (bewering) over een stakeholder-gerelateerde
         situatie: belangen, doelen, machtsverhoudingen, afhankelijkheden.
         Erft epistemische infrastructuur van Tessera. (DD-061, v0.2)"""@nl .

socia:InterestClaim
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf socia:StakeholderClaim ;
    rdfs:label "InterestClaim"@en , "Belangenclaim"@nl ;
    rdfs:comment
        """Een StakeholderClaim over het belang of concern van een
         Stakeholder bij een Issue. (DD-061)"""@nl .

socia:GoalClaim
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf socia:StakeholderClaim ;
    rdfs:label "GoalClaim"@en , "Doelclaim"@nl ;
    rdfs:comment
        """Een StakeholderClaim over het doel of de intentie van een
         Stakeholder in de context van een Issue. (DD-061)"""@nl .

socia:PowerClaim
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf socia:StakeholderClaim ;
    rdfs:label "PowerClaim"@en , "Machtsclaim"@nl ;
    rdfs:comment
        """Een StakeholderClaim over de machtspositie, invloed of
         hulpbronnen van een Stakeholder t.o.v. andere stakeholders.
         (DD-061)"""@nl .


###############################################################################
#  §D — IntentionalDependency (i*-dependum als SocialCommitment)
###############################################################################

socia:IntentionalDependency
    a owl:Class ;
    valor:ontoumlStereotype "relator" ;
    rdfs:subClassOf ufoc:SocialCommitment ;
    rdfs:label "IntentionalDependency"@en , "Intentionele afhankelijkheid"@nl ;
    rdfs:comment
        """Een i*-dependum als ufoc:SocialCommitment Relator tussen twee Agents.
         depender = claimant; dependee = committed agent.
         Kan geïnstantieerd worden als acta:Transaction. (DD-061)"""@nl .

socia:DependencyStrength
    a owl:Class ;
    rdf:type gufo:NonQualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "mode" ;
    rdfs:subClassOf gufo:IntrinsicMode ;
    rdfs:label "DependencyStrength"@en , "Afhankelijkheidssterkte"@nl ;
    rdfs:comment "Kritikaliteit van de afhankelijkheid: Open, Committed, Critical. (DD-061)"@nl .

socia:OpenDependency
    a socia:DependencyStrength ;
    rdfs:label "Open"@en , "Open afhankelijkheid"@nl ;
    rdfs:comment "Depender kan zijn doel alsnog bereiken zonder dependee. (DD-061)"@nl .

socia:CommittedDependency
    a socia:DependencyStrength ;
    rdfs:label "Committed"@en , "Gebonden afhankelijkheid"@nl ;
    rdfs:comment "Depender is gecommitteerd maar kan alternatieven zoeken. (DD-061)"@nl .

socia:CriticalDependency
    a socia:DependencyStrength ;
    rdfs:label "Critical"@en , "Kritieke afhankelijkheid"@nl ;
    rdfs:comment "Depender kan doel beslist niet bereiken zonder dependee. (DD-061)"@nl .


###############################################################################
#  §E — DependencyType (vier subtypen conform i*)
###############################################################################

socia:DependencyType
    a owl:Class ;
    rdfs:subClassOf gufo:SubKind ;
    gufo:partitions socia:IntentionalDependency ;
    rdfs:label "DependencyType"@en , "Afhankelijkheidstype"@nl ;
    rdfs:comment "Higher-Order Type voor i*-afhankelijkheidsclassificatie. (DD-063)"@nl .

socia:GoalDependency
    a owl:Class ;
    rdf:type socia:DependencyType ;
    rdfs:subClassOf socia:IntentionalDependency ;
    rdfs:label "GoalDependency"@en , "Doelafhankelijkheid"@nl ;
    owl:disjointWith socia:TaskDependency , socia:ResourceDependency , socia:SoftGoalDependency ;
    rdfs:comment "Outcome-afhankelijkheid. Propositional content: ufoc:Goal-Situation. (DD-063)"@nl .

socia:TaskDependency
    a owl:Class ;
    rdf:type socia:DependencyType ;
    rdfs:subClassOf socia:IntentionalDependency ;
    rdfs:label "TaskDependency"@en , "Taakafhankelijkheid"@nl ;
    owl:disjointWith socia:GoalDependency , socia:ResourceDependency , socia:SoftGoalDependency ;
    rdfs:comment "Process-afhankelijkheid. Propositional content: gufo:Action. (DD-063)"@nl .

socia:ResourceDependency
    a owl:Class ;
    rdf:type socia:DependencyType ;
    rdfs:subClassOf socia:IntentionalDependency ;
    rdfs:label "ResourceDependency"@en , "Middelenafhankelijkheid"@nl ;
    owl:disjointWith socia:GoalDependency , socia:TaskDependency , socia:SoftGoalDependency ;
    rdfs:comment "Beschikbaarheidsafhankelijkheid. Propositional content: gufo:Situation. (DD-063)"@nl .

socia:SoftGoalDependency
    a owl:Class ;
    rdf:type socia:DependencyType ;
    rdfs:subClassOf socia:IntentionalDependency ;
    rdfs:label "SoftGoalDependency"@en , "Kwaliteitsafhankelijkheid"@nl ;
    owl:disjointWith socia:GoalDependency , socia:TaskDependency , socia:ResourceDependency ;
    rdfs:comment "Kwaliteitseis-afhankelijkheid. Propositional content: ufoc:SoftGoal-Situation. (DD-063)"@nl .


###############################################################################
#  §F — ActorBoundary
###############################################################################

socia:ActorBoundary
    a owl:Class ;
    rdf:type gufo:SituationType ;
    valor:ontoumlStereotype "situation" ;
    rdfs:subClassOf gufo:Situation ;
    rdfs:label "ActorBoundary"@en , "Actorgrens"@nl ;
    rdfs:comment
        """De intentionele grens van een Stakeholder: interne intentionele
         elementen + externe afhankelijkheden. Conform i*: 'intentional
         boundary'. (DD-064)"""@nl .

socia:InternalElement
    a owl:Class ;
    rdf:type gufo:NonQualitativeIntrinsicAspect ;
    valor:ontoumlStereotype "mode" ;
    rdfs:subClassOf gufo:IntrinsicMode ;
    rdfs:label "InternalElement"@en , "Intern element"@nl ;
    rdfs:comment "Een intentioneel element binnen de ActorBoundary. (DD-064)"@nl .

socia:InternalGoal
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf socia:InternalElement ;
    rdfs:subClassOf ufoc:Goal ;
    rdfs:label "InternalGoal"@en , "Intern doel"@nl ;
    rdfs:comment "Een Goal die de actor intern nastreeft. (DD-064)"@nl .

socia:InternalTask
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf socia:InternalElement ;
    rdfs:label "InternalTask"@en , "Interne taak"@nl ;
    rdfs:comment "Een werkwijze die de actor intern hanteert. (DD-064)"@nl .

socia:InternalResource
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf socia:InternalElement ;
    rdfs:label "InternalResource"@en , "Intern middel"@nl ;
    rdfs:comment "Een object dat de actor intern beschikbaar heeft. (DD-064)"@nl .

socia:InternalSoftGoal
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf socia:InternalElement ;
    rdfs:subClassOf ufoc:SoftGoal ;
    rdfs:label "InternalSoftGoal"@en , "Interne kwaliteitseis"@nl ;
    rdfs:comment "Een kwaliteitseis die de actor intern nastreeft. (DD-064)"@nl .


###############################################################################
#  §G — StakeholderMap
###############################################################################

socia:StakeholderMap
    a owl:Class ;
    rdf:type gufo:SubKind ;
    valor:ontoumlStereotype "subkind" ;
    rdfs:subClassOf ufoc:SocialObject ;
    rdfs:label "StakeholderMap"@en , "Belanghebbendenkaart"@nl ;
    rdfs:comment
        """Een overzicht van alle Stakeholders + IntentionalDependencies
         t.o.v. een valor:Issue. Meerdere maps als alternatieven mogelijk.
         (DD-065)"""@nl .


###############################################################################
#  §H — Properties
###############################################################################

socia:isStakeholderIn
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "is stakeholder in"@en , "is belanghebbende bij"@nl ;
    rdfs:domain socia:Stakeholder ;
    rdfs:range  valor:Issue ;
    rdfs:comment "Het Issue waarbij deze Stakeholder betrokken is. (DD-061)"@nl .

socia:playsRole
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "plays role"@en , "speelt rol"@nl ;
    rdfs:domain socia:Stakeholder ;
    rdfs:range  socia:StakeholderRole ;
    rdfs:comment "De StakeholderRole van deze Stakeholder. (DD-062)"@nl .

socia:hasInterestProfile
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "has interest profile"@en , "heeft belangenprofiel"@nl ;
    rdfs:domain socia:Stakeholder ;
    rdfs:range  socia:StakeholderInterestProfile ;
    rdfs:comment "Het StakeholderInterestProfile van deze Stakeholder. (DD-062)"@nl .

socia:hasBoundary
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "has boundary"@en , "heeft actorgrens"@nl ;
    rdfs:domain socia:Stakeholder ;
    rdfs:range  socia:ActorBoundary ;
    rdfs:comment "De ActorBoundary van deze Stakeholder. (DD-064)"@nl .

socia:depender
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:subPropertyOf ufoc:hasClaimantAgent ;
    rdfs:label "depender"@en , "afhankelijke actor"@nl ;
    rdfs:domain socia:IntentionalDependency ;
    rdfs:range  socia:Stakeholder ;
    rdfs:comment "De Stakeholder die afhankelijk is (claimant). (DD-061)"@nl .

socia:dependee
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:subPropertyOf ufoc:hasCommittedAgent ;
    rdfs:label "dependee"@en , "leverancier actor"@nl ;
    rdfs:domain socia:IntentionalDependency ;
    rdfs:range  socia:Stakeholder ;
    rdfs:comment "De Stakeholder waarvan de depender afhankelijk is (committed). (DD-061)"@nl .

socia:hasDependencyStrength
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "characterization" ;
    rdfs:label "has dependency strength"@en , "heeft afhankelijkheidssterkte"@nl ;
    rdfs:domain socia:IntentionalDependency ;
    rdfs:range  socia:DependencyStrength ;
    rdfs:comment "De kritikaliteit van de afhankelijkheid. (DD-061)"@nl .

socia:dependencyContext
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "dependency context"@en , "afhankelijkheidscontext"@nl ;
    rdfs:domain socia:IntentionalDependency ;
    rdfs:range  valor:Issue ;
    rdfs:comment "Het Issue in de context waarvan deze afhankelijkheid bestaat. (DD-061)"@nl .

socia:boundaryContains
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "componentOf" ;
    rdfs:label "boundary contains"@en , "grens bevat"@nl ;
    rdfs:domain socia:ActorBoundary ;
    rdfs:range  socia:InternalElement ;
    rdfs:comment "Interne intentionele elementen binnen deze ActorBoundary. (DD-064)"@nl .

socia:boundaryHasDependency
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "boundary has dependency"@en , "grens heeft afhankelijkheid"@nl ;
    rdfs:domain socia:ActorBoundary ;
    rdfs:range  socia:IntentionalDependency ;
    rdfs:comment "De afhankelijkheden die de grens overschrijden. (DD-064)"@nl .

socia:mapIncludesStakeholder
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "map includes stakeholder"@en , "kaart bevat belanghebbende"@nl ;
    rdfs:domain socia:StakeholderMap ;
    rdfs:range  socia:Stakeholder ;
    rdfs:comment "De Stakeholders in deze StakeholderMap. (DD-065)"@nl .

socia:mapIncludesDependency
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "map includes dependency"@en , "kaart bevat afhankelijkheid"@nl ;
    rdfs:domain socia:StakeholderMap ;
    rdfs:range  socia:IntentionalDependency ;
    rdfs:comment "De IntentionalDependencies in deze StakeholderMap. (DD-065)"@nl .

socia:mapAddressesIssue
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "map addresses issue"@en , "kaart adresseert vraagstuk"@nl ;
    rdfs:domain socia:StakeholderMap ;
    rdfs:range  valor:Issue ;
    rdfs:comment "Het Issue van deze StakeholderMap. (DD-065)"@nl .

socia:mapAuthor
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "map author"@en , "kaartauteur"@nl ;
    rdfs:domain socia:StakeholderMap ;
    rdfs:range  ufoc:Agent ;
    rdfs:comment "De auteur(s) van deze StakeholderMap. (DD-065)"@nl .

socia:mapCreatedAt
    a owl:DatatypeProperty ;
    rdfs:label "map created at"@en ;
    rdfs:domain socia:StakeholderMap ;
    rdfs:range  xsd:dateTime ;
    rdfs:comment "Aanmaaktijdstip van de StakeholderMap. (DD-065)"@nl .

# ── Koppeling SOCIA → Tessera (v0.2) ─────────────────────────────────────────

socia:stakeholderSubmitsClaim
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "stakeholder submits claim"@en , "belanghebbende dient claim in"@nl ;
    rdfs:domain socia:Stakeholder ;
    rdfs:range  valor:Tessera ;
    rdfs:comment
        """De Tesserae die deze Stakeholder heeft ingediend. Gewijzigd v0.2:
         range was causa:CausalClaim (te specifiek); nu valor:Tessera zodat
         alle claimtypen (causa, socia, axia enz.) worden omvat. (DD-061)"""@nl .

# ── Koppeling SOCIA → ACTA ────────────────────────────────────────────────────

socia:dependencyInstantiatedAs
    a owl:ObjectProperty ;
    valor:ontoumlStereotype "mediation" ;
    rdfs:label "dependency instantiated as"@en , "afhankelijkheid geïnstantieerd als"@nl ;
    rdfs:domain socia:IntentionalDependency ;
    rdfs:range  <https://valor-ecosystem.nl/ontology/acta#Transaction> ;
    rdfs:comment
        """Koppeling van een IntentionalDependency naar de acta:Transaction
         die de afhankelijkheid transactioneel uitwerkt. (DD-061)"""@nl .

###############################################################################
#  Einde module 00i-socia.trig (v0.2)
###############################################################################
}
